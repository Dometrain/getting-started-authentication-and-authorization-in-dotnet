<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sample Application</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Debug panel styles */
        .debug-section {
            display: none; /* Hidden by default */
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 15px;
            margin-bottom: 10px;
        }

        .debug-link {
            color: #6c757d;
            text-decoration: none;
            margin-right: 15px;
        }

            .debug-link:hover {
                color: #495057;
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Sample Application</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/UserDebug/UserInfo" title="User Details">Debug</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/UserProfile/Index">Hello @(User?.Identity?.Name ?? "Unknown")</a>
                            </li>
                        
                            <li class="nav-item">
                                <form action="/Users/Logout" class="form-inline" method="post">
                                    <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <form asp-controller="Users" asp-action="Login" class="form-inline" method="get">
                                    <button type="submit" class="nav-link btn btn-link text-dark">Login</button>
                                </form>

                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - <a href="https://nestenius.se">Tore Nestenius</a>

            <span class="float-end">
                <a href="#" class="debug-link" onclick="toggleDebug('debugAuth'); return false;">Authorization</a>
                <a href="#" class="debug-link" onclick="toggleDebug('debugUser'); return false;">User</a>
                <a href="#" class="debug-link" onclick="toggleDebug('debugEndpoint'); return false;">Endpoint</a>
            </span>
        </div>
    </footer>

    <!-- Debug Sections (Hidden by default, stacked vertically) -->
    <div class="container">
        <div id="debugAuth" class="debug-section">
            <partial name="_DebugAuthorization" />
        </div>

        <div id="debugUser" class="debug-section">
            <partial name="_DebugUser" />
        </div>

        <div id="debugEndpoint" class="debug-section">
            <partial name="_DebugEndpoint" />
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Simple Debug Toggle Script -->
    <script>
        function toggleDebug(sectionId) {
            $('#' + sectionId).slideToggle(300);
        }
    </script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
