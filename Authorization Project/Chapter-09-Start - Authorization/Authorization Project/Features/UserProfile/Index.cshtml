@using StartcodeAuthorization.Features.UserProfile
@model UserProfileViewModel
@{
    ViewData["Title"] = Model?.UserProfile?.GetNameClaim() ?? "User Not Found";
}
<div class="container mt-4">
    @if (Model?.UserProfile != null)
    {
        <div class="card">
            <div class="card-header">
                <h2>User Profile Information</h2>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">User ID:</dt>
                            <dd class="col-sm-8">@Model.UserProfile.UserID</dd>
                            <dt class="col-sm-4">Name:</dt>
                            <dd class="col-sm-8">@Model.UserProfile.GetNameClaim() (<a href="/UserProfile/updateuser">Update</a>)</dd>
                            <dt class="col-sm-4">Country:</dt>
                            <dd class="col-sm-8">@Model.UserProfile.Country</dd>
                            <dt class="col-sm-4">Website:</dt>
                            <dd class="col-sm-8">
                                @if (!string.IsNullOrEmpty(Model.UserProfile.Website))
                                {
                                    <a href="@Model.UserProfile.Website" target="_blank" class="btn btn-link p-0">
                                        @Model.UserProfile.Website
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title">Quick Info</h5>
                                <p class="card-text">
                                    <strong>@Model.UserProfile.GetNameClaim()</strong> is a user from <strong>@Model.UserProfile.Country</strong>.
                                </p>
                                @if (!string.IsNullOrEmpty(Model.UserProfile.Website))
                                {
                                    <p class="card-text">
                                        Visit their website:
                                        <a href="@Model.UserProfile.Website" target="_blank">@Model.UserProfile.Website</a>
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Invoices Section -->
        <div class="card mt-4">
            <div class="card-header">
                <h3>My Invoices</h3>
            </div>
            <div class="card-body">
                @if (Model.UserInvoices?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invoice in Model.UserInvoices)
                                {
                                    <tr>
                                        <td>@invoice.InvoiceNumber</td>
                                        <td>@invoice.Amount.ToString("C")</td>
                                        <td>@invoice.InvoiceDate.ToString("MM/dd/yyyy")</td>
                                        <td>
                                            <a href="/invoices/invoice/@invoice.Id" class="btn btn-sm btn-outline-primary">View</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info" role="alert">
                        <h5 class="alert-heading">No Invoices Found</h5>
                        <p>This user doesn't have any invoices yet.</p>
                    </div>
                }
            </div>
        </div>

        <div class="mt-3">
            <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">User Not Found</h4>
            <p>Sorry, we couldn't find a user with the requested ID.</p>
            <hr>
            <p class="mb-0">
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </p>
        </div>
    }
</div>