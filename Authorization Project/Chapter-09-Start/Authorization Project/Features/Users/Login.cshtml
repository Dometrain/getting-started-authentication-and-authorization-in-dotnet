@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

<div class="card">
    <div class="card-header">
        <h4>Login User</h4>
    </div>
    <div class="card-body">
        <p class="mb-3">Choose a test user to login as:</p>
        <div class="row g-1">
            <div class="col-md-6 col-lg-4">
                <form action="/Users/Login" method="post" class="d-grid">
                    <input type="hidden" name="id" value="1" />
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-user"></i> Login as Alice (Customer)
                    </button>
                </form>
                <small class="text-muted">UserID: 1, Roles: None</small>
            </div>
        </div>
        <br />
        <div class="row g-1">
            <br />
            <div class="col-md-6 col-lg-4">
                <form action="/Users/Login" method="post" class="d-grid">
                    <input type="hidden" name="id" value="2" />
